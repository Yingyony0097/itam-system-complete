# ============================
# ITAM System - Environment Config
# ============================
# ສຳເນົາໄຟລ໌ນີ້ເປັນ .env ແລ້ວຕັ້ງຄ່າ

# Database
DB_HOST=db
DB_NAME=itam_system
DB_USER=itam_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD
DB_CHARSET=utf8mb4

# MySQL Root
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# App Mode: development | production
APP_ENV=production
